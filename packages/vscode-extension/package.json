{
  "name": "codelumeai",
  "displayName": "CodeLumeAI",
  "description": "Read your code in plain English. Hover any function to see what it does.",
  "version": "0.0.0",
  "private": true,
  "publisher": "nic-ai",
  "license": "MIT",
  "author": "Nicolas Sakr <sakrnicolas@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nicolas4485/codelumeai"
  },
  "categories": ["Programming Languages", "Education", "Other"],
  "keywords": ["plain english", "explain code", "claude", "anthropic", "translation", "ai"],
  "engines": {
    "vscode": "^1.95.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:html",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:java",
    "onLanguage:csharp",
    "onLanguage:ruby",
    "onLanguage:php"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codelumeai.setApiKey",
        "title": "Set Anthropic API Key",
        "category": "CodeLumeAI"
      },
      {
        "command": "codelumeai.clearApiKey",
        "title": "Clear Anthropic API Key",
        "category": "CodeLumeAI"
      },
      {
        "command": "codelumeai.toggleMode",
        "title": "Toggle Mode (Off / Hover / Always-on)",
        "category": "CodeLumeAI"
      },
      {
        "command": "codelumeai.translateCurrentFile",
        "title": "Translate Current File",
        "category": "CodeLumeAI"
      },
      {
        "command": "codelumeai.showLogs",
        "title": "Show Logs",
        "category": "CodeLumeAI"
      }
    ],
    "configuration": {
      "title": "CodeLumeAI",
      "properties": {
        "codelumeai.mode": {
          "type": "string",
          "enum": ["off", "hover", "always-on"],
          "default": "hover",
          "description": "How translations are displayed. 'hover' = on-demand tooltips. 'always-on' = inline hints. 'off' = disabled."
        },
        "codelumeai.model": {
          "type": "string",
          "enum": ["claude-haiku-4-5", "claude-sonnet-4-6"],
          "default": "claude-haiku-4-5",
          "description": "Anthropic model used for translation. Haiku is fast and cheap; Sonnet is higher quality at higher cost."
        },
        "codelumeai.maxFileLines": {
          "type": "number",
          "default": 2000,
          "description": "Skip files larger than this many lines (cost guardrail)."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "codelumeai.gettingStarted",
        "title": "Get Started with CodeLumeAI",
        "description": "Read your code in plain English. Three steps to your first translation.",
        "steps": [
          {
            "id": "setApiKey",
            "title": "Add your Anthropic API key",
            "description": "Your key is stored in VS Code's SecretStorage — never in settings.json.\n[Set API Key](command:codelumeai.setApiKey)",
            "media": { "markdown": "walkthroughs/01-set-api-key.md" },
            "completionEvents": ["onCommand:codelumeai.setApiKey"]
          },
          {
            "id": "pickMode",
            "title": "Pick a default mode",
            "description": "Hover (on-demand), Always-on (inline summaries), or Off. Click the status bar to cycle.\n[Open Settings](command:workbench.action.openSettings?%22codelumeai%22)",
            "media": { "markdown": "walkthroughs/02-pick-mode.md" },
            "completionEvents": ["onLink:opened"]
          },
          {
            "id": "tryIt",
            "title": "Hover any line of code",
            "description": "Open a code file and move your mouse over a function or class.\n[Translate Current File](command:codelumeai.translateCurrentFile)",
            "media": { "markdown": "walkthroughs/03-try-it.md" },
            "completionEvents": ["onCommand:codelumeai.translateCurrentFile"]
          }
        ]
      }
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "build": "tsc",
    "vscode:prepublish": "tsc",
    "package": "vsce package",
    "clean": "rimraf dist .turbo *.vsix"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@codelumeai/core": "workspace:*"
  }
}
