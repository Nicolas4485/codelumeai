{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CodeLumeAI Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension",
        "--new-window",
        "--disable-restore-windows",
        "C:\\Users\\sakrn\\Documents\\projects\\codelumeai"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-extension/dist/**/*.js",
        "${workspaceFolder}/packages/core/dist/**/*.js"
      ],
      "preLaunchTask": "build extension"
    }
  ]
}
